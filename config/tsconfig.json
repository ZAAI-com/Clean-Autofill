{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist",
    "rootDir": "../src",
    "declaration": false,
    "sourceMap": false,
    "moduleResolution": "bundler",
    "types": ["chrome"]
  },
  "include": ["../src/**/*.ts"],
  "exclude": ["../node_modules", "../dist", "../src/**/*.test.ts"]
}
